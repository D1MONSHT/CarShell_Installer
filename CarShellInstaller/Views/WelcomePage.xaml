<Page x:Class="CarShellInstaller.Views.WelcomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:CarShellInstaller.Views"
      mc:Ignorable="d"
      d:DesignHeight="550" d:DesignWidth="750"
      Title="Welcome">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Margin="20" Orientation="Vertical">
            <TextBlock Text="CarShell Installer" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center"/>
            <TextBlock Text="v1.0.0" FontSize="14" Foreground="Gray" HorizontalAlignment="Center"/>
        </StackPanel>
        <ScrollViewer Grid.Row="1" Margin="40" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Welcome to CarShell Installer" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,20"/>
                <TextBlock Text="This application will help you configure your Windows system for CarShell." TextWrapping="Wrap" Margin="0,0,0,20"/>
                <TextBlock Text="Features:" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                <StackPanel Margin="20,0,0,0">
                    <TextBlock Text="* WPF .NET 8 Application" Margin="0,5,0,5"/>
                    <TextBlock Text="* Installation Wizard" Margin="0,5,0,5"/>
                    <TextBlock Text="* Mode Selection (Windows / CarShell / Kiosk)" Margin="0,5,0,5"/>
                    <TextBlock Text="* JSON Profile System" Margin="0,5,0,5"/>
                    <TextBlock Text="* Settings Backup and Restore" Margin="0,5,0,5"/>
                    <TextBlock Text="* System Management Modules" Margin="0,5,0,5"/>
                </StackPanel>
                <TextBlock Text="Note: This is the first release. More features will be added soon." Foreground="Gray" Margin="0,20,0,0" TextWrapping="Wrap"/>
            </StackPanel>
        </ScrollViewer>
        <StackPanel Grid.Row="2" Margin="20" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="BtnNext" Content="Next" Width="100" Height="35" Margin="0,0,10,0" Click="BtnNext_Click"/>
            <Button x:Name="BtnCancel" Content="Cancel" Width="100" Height="35" Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Page>