<Page x:Class="CarShellInstaller.Views.OptionsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:CarShellInstaller.Views"
      mc:Ignorable="d"
      d:DesignHeight="550" d:DesignWidth="750"
      Title="Installation Options">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Margin="20" Orientation="Vertical">
            <TextBlock Text="Installation Options" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
            <TextBlock Text="Configure additional settings" FontSize="14" Foreground="Gray" HorizontalAlignment="Center"/>
        </StackPanel>
        <ScrollViewer Grid.Row="1" Margin="40" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <GroupBox Header="Profile" Margin="0,0,0,20">
                    <StackPanel>
                        <ComboBox x:Name="CmbProfile" Margin="10" Height="30">
                            <ComboBoxItem Content="Standard" IsSelected="True"/>
                            <ComboBoxItem Content="CarMode"/>
                            <ComboBoxItem Content="ExtremeKiosk"/>
                        </ComboBox>
                        <TextBlock Text="Select a predefined configuration profile" Foreground="Gray" Margin="10,0,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </GroupBox>
                <GroupBox Header="Backup" Margin="0,0,0,20">
                    <StackPanel>
                        <CheckBox x:Name="ChkCreateBackup" Content="Create system backup" IsChecked="True" Margin="10,5,0,5"/>
                        <CheckBox x:Name="ChkRestorePoint" Content="Create Windows restore point" IsChecked="True" Margin="10,5,0,5"/>
                    </StackPanel>
                </GroupBox>
                <GroupBox Header="Advanced" Margin="0,0,0,20">
                    <StackPanel>
                        <CheckBox x:Name="ChkDisableServices" Content="Disable unnecessary services" IsChecked="True" Margin="10,5,0,5"/>
                        <CheckBox x:Name="ChkOptimizeWindows" Content="Apply Windows optimizations" IsChecked="True" Margin="10,5,0,5"/>
                        <CheckBox x:Name="ChkPowerManagement" Content="Configure power management" IsChecked="True" Margin="10,5,0,5"/>
                        <CheckBox x:Name="ChkRegistryTweaks" Content="Apply registry tweaks" IsChecked="True" Margin="10,5,0,5"/>
                    </StackPanel>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>
        <StackPanel Grid.Row="2" Margin="20" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="BtnBack" Content="Back" Width="100" Height="35" Margin="0,0,10,0" Click="BtnBack_Click"/>
            <Button x:Name="BtnNext" Content="Next" Width="100" Height="35" Click="BtnNext_Click"/>
            <Button x:Name="BtnCancel" Content="Cancel" Width="100" Height="35" Margin="10,0,0,0" Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Page>