<Page x:Class="CarShellInstaller.Views.FinishPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:CarShellInstaller.Views"
      mc:Ignorable="d"
      d:DesignHeight="550" d:DesignWidth="750"
      Title="Installation Complete">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Margin="20" Orientation="Vertical">
            <TextBlock x:Name="TxtHeader" Text="Installation Complete!" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center"/>
        </StackPanel>
        <ScrollViewer Grid.Row="1" Margin="40" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock x:Name="TxtSummary" Text="CarShell Installer has been successfully installed." FontSize="16" Margin="0,0,0,20" TextWrapping="Wrap"/>
                <Border BorderBrush="LightGray" BorderThickness="1" CornerRadius="5" Padding="20" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="Installation Details:" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,10"/>
                        <TextBlock x:Name="TxtMode" Text="Mode: Not selected" Margin="0,5,0,5"/>
                        <TextBlock x:Name="TxtProfile" Text="Profile: Not selected" Margin="0,5,0,5"/>
                        <TextBlock x:Name="TxtBackup" Text="Backup: Not created" Margin="0,5,0,5"/>
                    </StackPanel>
                </Border>
                <TextBlock Text="What next?" FontSize="16" FontWeight="SemiBold" Margin="0,20,0,10"/>
                <StackPanel Margin="20,0,0,0">
                    <TextBlock Text="* The system may need to be restarted for changes to take effect" Margin="0,5,0,5"/>
                    <TextBlock Text="* Check the backup files in the installation directory" Margin="0,5,0,5"/>
                    <TextBlock Text="* Review the installation log for details" Margin="0,5,0,5"/>
                </StackPanel>
                <TextBlock x:Name="TxtError" Text="" Foreground="Red" Margin="0,20,0,0" TextWrapping="Wrap" Visibility="Collapsed"/>
            </StackPanel>
        </ScrollViewer>
        <StackPanel Grid.Row="2" Margin="20" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="BtnFinish" Content="Finish" Width="100" Height="35" Click="BtnFinish_Click"/>
        </StackPanel>
    </Grid>
</Page>