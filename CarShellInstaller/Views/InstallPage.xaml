<Page x:Class="CarShellInstaller.Views.InstallPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:CarShellInstaller.Views"
      mc:Ignorable="d"
      d:DesignHeight="550" d:DesignWidth="750"
      Title="Installation">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Margin="20" Orientation="Vertical">
            <TextBlock Text="Installing CarShell" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
            <TextBlock x:Name="TxtStatus" Text="Initializing..." FontSize="14" Foreground="Gray" HorizontalAlignment="Center"/>
        </StackPanel>
        <ScrollViewer Grid.Row="1" Margin="40" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <ProgressBar x:Name="ProgressBar" Value="0" Maximum="100" Height="20" Margin="0,0,0,20"/>
                <Border BorderBrush="LightGray" BorderThickness="1" CornerRadius="5" Padding="10">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Height="300">
                        <TextBlock x:Name="TxtLog" TextWrapping="Wrap" FontFamily="Consolas"/>
                    </ScrollViewer>
                </Border>
            </StackPanel>
        </ScrollViewer>
        <StackPanel Grid.Row="2" Margin="20" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="BtnBack" Content="Back" Width="100" Height="35" Margin="0,0,10,0" Click="BtnBack_Click"/>
            <Button x:Name="BtnInstall" Content="Install" Width="100" Height="35" Click="BtnInstall_Click"/>
            <Button x:Name="BtnCancel" Content="Cancel" Width="100" Height="35" Margin="10,0,0,0" Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Page>